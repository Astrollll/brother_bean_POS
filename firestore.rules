rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function userDocPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function userDocExists() {
      return exists(userDocPath());
    }

    function role() {
      return userDocExists() ? get(userDocPath()).data.role : null;
    }

    function isLegacyAdmin() {
      return isSignedIn() && (!userDocExists() || role() == null);
    }

    function isAdmin() {
      return isSignedIn() && (role() == "admin" || isLegacyAdmin());
    }

    function isWorker() {
      return isSignedIn() && ((role() in ["admin", "staff"]) || isLegacyAdmin());
    }

    // Users can read their own profile; only admins can write roles for others.
    match /users/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow create: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow update, delete: if isAdmin();
    }

    match /inventory/{docId} {
      allow read: if isWorker();
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (
        isWorker() &&
        request.resource.data.id == resource.data.id &&
        request.resource.data.name == resource.data.name &&
        request.resource.data.category == resource.data.category &&
        request.resource.data.unit == resource.data.unit &&
        request.resource.data.reorderLevel == resource.data.reorderLevel &&
        request.resource.data.price == resource.data.price &&
        request.resource.data.quantity is number &&
        request.resource.data.updatedAtMs is number
      );
    }

    match /menu/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /categories/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /staff/{docId} {
      allow read: if isWorker();
      allow write: if isAdmin();
    }

    match /schedule/{docId} {
      allow read: if isWorker();
      allow write: if isAdmin();
    }

    match /orders/{docId} {
      allow create: if isWorker();
      allow update: if isWorker();
      allow read, delete: if isAdmin();
    }

    match /resets/{dateId} {
      allow read, write: if isAdmin();

      match /orders/{orderDocId} {
        allow read, write: if isAdmin();
      }
    }
  }
}

