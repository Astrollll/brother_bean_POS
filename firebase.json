{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "firestore.rules",
      "**/.*",
      "**/node_modules/**"
    ],
    "redirects": [
      {
        "source": "/",
        "destination": "/views/pages/login.html",
        "type": 302
      }
    ],
    "rewrites": [
      {
        "source": "/",
        "destination": "/views/pages/login.html"
      },
      {
        "source": "/login",
        "destination": "/views/pages/login.html"
      },
      {
        "source": "/admin",
        "destination": "/views/pages/admin.html"
      },
      {
        "source": "/pos",
        "destination": "/views/pages/pos.html"
      }
    ],
    "headers": [
      {
        "source": "**/*.js",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache"
          }
        ]
      }
    ]
  },
  "firestore": {
    "rules": "firestore.rules"
  }
}
