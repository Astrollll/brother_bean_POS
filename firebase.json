{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "firestore.rules",
      "firestore.indexes.json",
      "**/.*",
      "**/node_modules/**",
      "package.json",
      "package-lock.json",
      "TODO.md",
      "CHANGELOG.md",
      "README.md",
      "scripts/**",
      "config/app.config.example.js"
    ],
    "redirects": [
      {
        "source": "/",
        "destination": "/views/pages/login.html",
        "type": 302
      }
    ],
    "rewrites": [
      {
        "source": "/",
        "destination": "/views/pages/login.html"
      },
      {
        "source": "/login",
        "destination": "/views/pages/login.html"
      },
      {
        "source": "/admin",
        "destination": "/views/pages/admin.html"
      },
      {
        "source": "/pos",
        "destination": "/views/pages/pos.html"
      }
    ],
    "headers": [
      {
        "source": "**/*.js",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache"
          }
        ]
      },
      {
        "source": "**/*.css",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache"
          }
        ]
      }
    ]
  },
  "firestore": {
    "rules": "firestore.rules"
  }
}
